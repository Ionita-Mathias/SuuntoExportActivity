# Required for OAuth2 (API mode)
SUUNTO_CLIENT_ID=your_client_id
SUUNTO_CLIENT_SECRET=your_client_secret
SUUNTO_SUBSCRIPTION_KEY=your_subscription_key

# OAuth2 endpoints
SUUNTO_OAUTH_TOKEN_URL=https://cloudapi-oauth.suunto.com/oauth/token
SUUNTO_OAUTH_AUTHORIZE_URL=https://cloudapi-oauth.suunto.com/oauth/authorize

# API endpoint
SUUNTO_API_BASE_URL=https://cloudapi.suunto.com

# Redirect URI registered in Suunto API zone
SUUNTO_REDIRECT_URI=http://localhost:8080/callback

# Optional scopes (space-separated)
SUUNTO_SCOPE=workouts.read

# Optional: your estimated max HR for zone computation
SUUNTO_MAX_HR=190

# Token cache file
# Local Python: .tokens/suunto_token.json
# Docker: leave this value, it maps to /app/.tokens via docker-compose volume
SUUNTO_TOKEN_PATH=.tokens/suunto_token.json

# CLI defaults (used directly from env, handy in Docker)
SUUNTO_OUTPUT_DIR=./output
SUUNTO_EXPORT_START_DATE=
SUUNTO_EXPORT_END_DATE=

# Optional for parse-local (if set, --input is no longer required)
# Docker default in compose is /data
SUUNTO_LOCAL_INPUT=
